# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Telegram bot (step 1) ---
# Create a bot with @BotFather, paste its token here.
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...

# Your numeric Telegram user id (ask @userinfobot). The bot only responds
# to this one user — it is private.
TOKCUT_ALLOWED_USER_ID=000000000

# Optional. Where downloaded clips and renders are kept.
TOKCUT_WORKDIR=~/.tokcut/work

# Optional. Default target output length in seconds.
TOKCUT_TARGET=50

# --- Local Bot API server (step 5 — for clips over 50 MB) ---
# The cloud Bot API caps up/downloads at 50 MB; a full iPhone clip is ~250 MB.
# Run your own telegram-bot-api (see docker-compose.botapi.yml) and point the
# bot at it here to lift the cap to 2 GB. Leave unset to use the cloud API.
TOKCUT_BOT_API_URL=
# Needed only by docker-compose.botapi.yml (from https://my.telegram.org):
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Optional. Shared download dir for the server + bot (must match on both).
TELEGRAM_BOT_API_DIR=/var/lib/telegram-bot-api

# --- Claude Code subscription OAuth (step 3 — not used yet) ---
# Generate a long-lived token from your Claude subscription with:
#   claude setup-token
# Claude Code / the Agent SDK pick this up for the judgment work
# (caption wording, output review). Keep it secret.
CLAUDE_CODE_OAUTH_TOKEN=
