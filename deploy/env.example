# Copy to /etc/tokcut/env on the VPS and fill in. Keep it root-readable
# only:  sudo install -m 600 -o root deploy/env.example /etc/tokcut/env
#
# This is the systemd EnvironmentFile for tokcut-bot.service — the same
# variables as the repo's .env.example, minus the docker-compose-only ones.

TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token...
TOKCUT_ALLOWED_USER_ID=000000000
TOKCUT_WORKDIR=/home/tokcut/.tokcut/work
TOKCUT_TARGET=auto
# x265 preset: "medium" (default, best quality/size) — use "fast" on
# small shared boxes (2 cores) to roughly halve encode times.
TOKCUT_PRESET=fast

# Local Bot API server (the bootstrap starts it on this host)
TOKCUT_BOT_API_URL=http://127.0.0.1:8081

# Long-lived Claude subscription token — generate ON YOUR OWN MACHINE
# with `claude setup-token` and paste it here.
CLAUDE_CODE_OAUTH_TOKEN=

# Needed by docker-compose.botapi.yml (from https://my.telegram.org):
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_DIR=/var/lib/telegram-bot-api
